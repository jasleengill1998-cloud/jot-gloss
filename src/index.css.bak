@tailwind base;
@tailwind components;
@tailwind utilities;

/*
  PALETTE — CLEAN BRIGHT PASTELS (No Dusty/Muted Tones)

  PRIMARY:
    Baby Pink:          #F0E8E4 (sidebar, containers)
    Soft Pink White:    #FFF4F6 (main background)

  SUPPORTING PASTELS:
    Powder Blue:        #A8C8F0 / #E0ECF8
    Fresh Mint:         #90D8A8 / #E0F5E0
    Baby Pink:          #FFB8C8
    Soft Lilac:         #C8B0E8 / #EDE7F3
    Rose Pink:          #F0A0B4
    Warm Pink:          #F8A0C0
    Peach:              #FFD0B8

  BORDERS/ACCENTS:
    Rose Border:        #E8A0B0
    Bright Coral:       #C88898
    Plum Text:          #5A3E4B
    Vine Green:         #70B880
    Leaf Bright:        #80C890

  RULES:
    - NO dusty/gray undertone colors
    - Every surface uses CLEAN bright pastel tints
    - Multicolor pastels in florals
    - Visible ornamentation (not ghost-faint)
*/

@layer base {
  body {
    @apply font-body antialiased;
    color: #5A3E4B;
    min-height: 100dvh;
    background-color: #F8D8E0;
    /* Wallpaper on body is hidden by sidebar/main-desk surfaces */
  }
  ::selection { background: rgba(240,160,180,0.4) }
  h1, h2, h3 { color: #5A3E4B }
}

@layer components {

  .world-frame {
    max-width: 1520px;
    margin: 0 auto;
    position: relative;
  }
  .world-frame-inner { position: relative }

  .portal-shell {
    display: grid;
    grid-template-columns: 260px 1fr;
    min-height: 100vh;
  }
  @media (max-width: 1024px) {
    .portal-shell { grid-template-columns: 1fr; }
  }

  /* ═══ SIDEBAR — sticky, clean solid background ═══ */
  .archive-rail {
    background: #FFF4F0;
    border-right: 1px solid rgba(200,136,152,0.15);
    display: flex;
    flex-direction: column;
    padding: 0 8px;
    color: #5A3E4B;
    position: sticky;
    top: 0;
    align-self: start;
    height: 100vh;
    overflow-y: auto;
  }
  @media (max-width: 1024px) {
    .archive-rail {
      flex-direction: row;
      overflow-x: auto;
      border-bottom: 1px solid rgba(200,168,140,0.2);
      scrollbar-width: none;
      background: rgba(255,244,240,0.95);
      backdrop-filter: blur(8px);
      padding: 0;
    }
    .archive-rail::-webkit-scrollbar { display: none }
  }

  /* Arch container — desktop only */
  .sidebar-arch {
    flex-direction: column;
    height: 100vh;
    position: sticky;
    top: 0;
  }

  .sidebar-arch-top { flex-shrink: 0 }

  /* Double gold borders on sides — outer border */
  .sidebar-arch-sides {
    flex: 1;
    overflow-y: auto;
    background: #FFF8F0;
    border-left: 1.3px solid rgba(184,149,106,0.55);
    border-right: 1.3px solid rgba(184,149,106,0.55);
    margin: -1px 3px 0;
    padding: 0 7px;
    scrollbar-width: thin;
    scrollbar-color: rgba(200,168,140,0.25) transparent;
  }
  .sidebar-arch-sides::-webkit-scrollbar { width: 4px }
  .sidebar-arch-sides::-webkit-scrollbar-track { background: transparent }
  .sidebar-arch-sides::-webkit-scrollbar-thumb { background: rgba(200,168,140,0.25); border-radius: 2px }

  /* Inner gold border */
  .sidebar-arch-content {
    border-left: 0.8px solid rgba(200,168,120,0.35);
    border-right: 0.8px solid rgba(200,168,120,0.35);
    padding: 10px 12px;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .sidebar-arch-bottom {
    flex-shrink: 0;
    margin-top: -1px;
  }

  .sidebar-section { padding: 4px 0 }
  .sidebar-diamond-divider { padding: 6px 0 }

  /* Sidebar group containers — mobile fallback */
  .sidebar-group {
    padding: 10px 16px 12px;
    margin: 4px 10px;
    position: relative;
    z-index: 1;
    border: none;
  }
  .sidebar-group-blush { background: transparent }
  .sidebar-group-sage { background: transparent }
  .sidebar-group-powder { background: transparent }
  @media (max-width: 1024px) {
    .sidebar-group { margin: 0; padding: 0 12px; border: none }
  }

  .rail-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: #5A3E4B;
    padding-bottom: 5px;
    margin-bottom: 6px;
    border-bottom: 1px solid rgba(200,168,120,0.2);
    position: relative;
  }

  .rail-item {
    display: flex;
    align-items: center;
    width: 100%;
    text-align: left;
    padding: 7px 12px 7px 14px;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 13px;
    font-weight: 500;
    color: #5A3E4B;
    background: none;
    border: none;
    border-left: 2.5px solid transparent;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    position: relative;
  }
  .rail-item:hover {
    background: rgba(240,200,210,0.3);
    color: #5A3E4B;
  }
  .rail-item.active {
    background: rgba(240,200,210,0.35);
    border-left-color: #C88898;
    color: #C88898;
    font-weight: 700;
    border-radius: 0 3px 3px 0;
    margin-right: 2px;
  }
  @media (max-width: 1024px) {
    .rail-item { border-left: none; border-bottom: 2.5px solid transparent; padding: 12px 16px; min-height: 44px }
    .rail-item.active { border-bottom-color: #C88898; border-left: none; border-radius: 0; margin-right: 0 }
  }

  /* ═══ MAIN DESK — seamless wallpaper, single cover image ═══ */
  .main-desk {
    background-color: #FFE8EE;
    background-image: url('/chinoiserie-wallpaper.png');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: center top;
    background-attachment: fixed;
    overflow-y: auto;
    position: relative;
  }
  /* Frosted overlay removed — wallpaper shows through directly */
  .main-desk-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 12px 48px 0;
    position: relative;
    z-index: 2;
  }
  @media (max-width: 1024px) {
    .main-desk-inner { padding: 20px 20px 0 }
  }

  /* ═══ MUGHAL CONTENT FRAME — clean rose borders ═══ */
  .mughal-content-frame {
    position: relative;
    margin: 0 16px 0 8px;
    padding: 0;
    z-index: 1;
  }
  .mughal-content-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1px solid rgba(240,160,180,0.1);
    pointer-events: none;
    z-index: 0;
  }
  .mughal-content-frame::after {
    content: '';
    position: absolute;
    inset: 4px;
    border: 0.5px solid rgba(240,160,180,0.15);
    pointer-events: none;
    z-index: 0;
  }

  /* Mughal frame ornamental corners */
  .mughal-corner {
    position: absolute;
    width: 20px;
    height: 20px;
    z-index: 1;
    pointer-events: none;
  }
  .mughal-corner svg { display: block }
  .mughal-corner-tl { top: -2px; left: -2px }
  .mughal-corner-tr { top: -2px; right: -2px; transform: scaleX(-1) }
  .mughal-corner-bl { bottom: -2px; left: -2px; transform: scaleY(-1) }
  .mughal-corner-br { bottom: -2px; right: -2px; transform: scale(-1) }

  /* ═══ SECTION SURFACE — frosted panel behind content blocks ═══ */
  .section-surface {
    background: rgba(255,248,248,0.82);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 2px;
    padding: 8px 0;
    position: relative;
  }

  /* ═══ MODAL / POPUP PANEL — unified design system ═══ */
  .modal-panel {
    background: rgba(255,248,248,0.95);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 2px solid #B8956A;
    box-shadow:
      0 12px 40px rgba(90,62,75,0.12),
      0 4px 12px rgba(90,62,75,0.06),
      inset 0 0 0 4px rgba(255,248,248,0.5),
      inset 0 0 0 5px rgba(200,168,120,0.3);
    padding: 24px 28px;
    position: relative;
  }
  .modal-panel::before {
    content: '';
    position: absolute;
    inset: 8px;
    border: 0.5px solid rgba(200,168,120,0.2);
    pointer-events: none;
  }

  /* ═══ SECTION SPACING — consistent rhythm ═══ */
  .section-blush,
  .section-sage,
  .section-powder {
    padding: 16px 0;
    margin: 0 0 28px;
  }

  /* ═══ TITLE SYSTEM ═══ */
  .bloom-title-block {
    text-align: center;
    padding: 0;
    position: relative;
    max-width: 560px;
    margin: 0 auto 24px;
    background: none;
  }
  .bloom-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(28px, 5vw, 42px);
    font-weight: 700;
    color: #5A3E4B;
    letter-spacing: 0.08em;
    line-height: 1.15;
    font-variant: small-caps;
  }
  .bloom-title span {
    font-weight: 400;
    font-style: italic;
    color: #D4A0A8;
    font-variant: normal;
  }
  .bloom-stats {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    gap: 6px;
    margin-top: 8px;
  }
  .bloom-stats .collection-stat + .collection-stat::before {
    content: '\00b7';
    margin-right: 6px;
    color: rgba(240,160,180,0.5);
  }

  /* ═══ DESK TOOLS ═══ */
  .desk-tools-inset {
    display: flex;
    gap: 8px;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    padding: 10px 16px;
    max-width: 560px;
    margin: 0 auto 10px;
    background: linear-gradient(180deg, rgba(240,160,180,0.08), transparent);
    border-top: 1px solid rgba(184,160,144,0.08);
    border-bottom: 1px solid rgba(184,160,144,0.08);
    position: relative;
  }
  .desk-tool-btn {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: #5A3E4B;
    background: #FFF4F0;
    border: 1px solid rgba(240,160,180,0.35);
    cursor: pointer;
    padding: 0 16px;
    height: 32px;
    line-height: 32px;
    transition: all 0.2s ease;
    position: relative;
  }
  .desk-tool-btn:hover { background: rgba(240,160,180,0.2); border-color: rgba(240,160,180,0.5) }
  .desk-tool-btn.active { color: #C88898; font-weight: 700; border-color: #C88898 }

  /* ═══ SEARCH & FILTER ═══ */
  .search-filter-frame {
    border: none;
    background: transparent;
    padding: 0 0 14px;
    margin-bottom: 12px;
    border-bottom: 1px solid rgba(184,160,144,0.06);
  }
  .index-search {
    background: transparent;
    border: none;
    border-bottom: 1px solid rgba(240,160,180,0.3);
    color: #5A3E4B;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 15px;
    font-style: italic;
    padding: 8px 0;
    width: 100%;
    transition: border-color 0.15s;
  }
  .index-search:focus { outline: none; border-bottom-color: #C88898 }
  .index-search::placeholder { color: rgba(240,160,180,0.45); font-style: italic }

  .filter-chip {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 4px 14px;
    border: 1px solid rgba(240,160,180,0.3);
    background: transparent;
    color: #C88898;
    cursor: pointer;
    border-radius: 2px;
    transition: all 0.12s;
  }
  .filter-chip:hover {
    background: rgba(240,160,180,0.15);
    border-color: rgba(240,160,180,0.5);
  }
  .filter-chip.active {
    background: linear-gradient(180deg, #FFB8C8, #F0A0B4);
    color: #5A3E4B;
    border-color: #F0A0B4;
  }

  .sort-link {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 11px;
    color: rgba(90,62,75,0.4);
    cursor: pointer;
    background: none;
    border: none;
    padding: 2px 0;
    transition: color 0.12s;
  }
  .sort-link:hover { color: #C88898 }
  .sort-link.active { color: #C88898; font-weight: 700; border-bottom: 1px solid #C88898 }

  /* ═══ SECTION LABELS ═══ */
  .section-label {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #5A3E4B;
    padding: 4px 12px;
    margin-bottom: 12px;
    background: rgba(255,244,240,0.85);
    border-bottom: 1.5px solid rgba(200,168,104,0.3);
    display: inline-block;
  }

  .gold-rule {
    border: none;
    margin: 16px auto;
    width: 280px;
    height: 20px;
    background-image: url('/mughal-border.png');
    background-size: 600px 20px;
    background-repeat: repeat-x;
    background-position: center;
    position: relative;
    opacity: 0.7;
  }
  .gold-rule::after {
    content: '';
    display: none;
    font-size: 10px;
  }

  .browse-all-btn:hover {
    color: #C88898 !important;
  }

  /* ═══ SHELF ITEMS ═══ */
  .shelf-item {
    display: flex;
    align-items: flex-start;
    gap: 14px;
    padding: 16px 0;
    border: none;
    border-bottom: 1px solid rgba(184,149,106,0.12);
    background: transparent;
    margin-bottom: 0;
    cursor: pointer;
    transition: all 0.15s;
    position: relative;
  }
  .shelf-item:hover {
    background: linear-gradient(90deg, rgba(240,160,180,0.1), transparent);
  }
  .shelf-spine {
    width: 3px;
    min-height: 36px;
    flex-shrink: 0;
    align-self: stretch;
    border-radius: 1px;
    opacity: 0.6;
  }

  /* ═══ STAMPS ═══ */
  .stamp {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 7px;
    border: 1px solid currentColor;
    border-radius: 1px;
  }
  .stamp-medallion {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 9px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid rgba(184,149,106,0.35);
    border-radius: 1px;
    color: #5A3E4B;
    background: rgba(255,244,240,0.6);
  }

  .panel-warm {
    background: linear-gradient(180deg, #FFF4F0, #F0E8E4);
    border: 1px solid rgba(240,160,180,0.2);
  }
  .input-warm {
    background: #FFF4F0;
    border: 1px solid rgba(240,160,180,0.25);
    color: #5A3E4B;
    font-family: 'Outfit', system-ui, sans-serif;
    transition: border-color 0.12s;
    border-radius: 2px;
  }
  .input-warm:focus { outline: none; border-color: #C88898 }
  .input-warm::placeholder { color: rgba(240,160,180,0.35) }

  .btn-primary {
    background: linear-gradient(180deg, #FFB8C8, #F0A0B4);
    color: #5A3E4B;
    font-weight: 700;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 6px 18px;
    border: 1px solid rgba(240,160,176,0.4);
    cursor: pointer;
    transition: all 0.12s;
    border-radius: 2px;
  }
  .btn-primary:hover { background: linear-gradient(180deg, #F0A0B4, #E890A8) }

  .frame-ornate {
    background: linear-gradient(180deg, #FFF4F0, #F0E8E4);
    border: 1px solid rgba(240,160,180,0.2);
    box-shadow: 0 4px 16px rgba(90,62,75,0.04);
    position: relative;
  }
  .frame-ornate::before {
    content: '';
    position: absolute;
    inset: 4px;
    border: 0.5px solid rgba(240,160,180,0.15);
    pointer-events: none;
  }

  .collection-stat {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 13px;
    font-style: italic;
    color: #5A3E4B;
  }

  .pinned-note {
    background: linear-gradient(180deg, rgba(144,216,168,0.08), rgba(240,160,180,0.08));
    border: 1px solid rgba(240,160,180,0.2);
    padding: 10px 14px;
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 12px;
    font-style: italic;
    color: #C88898;
  }

  /* ═══ CARD COLOR CYCLING — wallpaper-matched pastels ═══ */
  .card-tint-blush { background: rgba(255,224,218,0.55) }
  .card-tint-rose { background: rgba(255,216,228,0.5) }
  .card-tint-sage { background: rgba(214,238,218,0.55) }
  .card-tint-powder { background: rgba(210,230,250,0.5) }
  .card-tint-lavender { background: rgba(224,212,248,0.5) }

  /* ═══ 2-COLUMN CARD GRID — wider cards, aligned baselines ═══ */
  .card-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
    max-width: 920px;
    margin: 0 auto;
    align-items: start;
  }
  @media (max-width: 768px) {
    .card-grid { grid-template-columns: 1fr; gap: 16px }
  }

  /* ═══ MUGHAL ORNAMENTAL BORDER ═══ */
  .mughal-border {
    position: relative;
    border-image: url('/ornate-border.svg') 30 round;
    border-width: 12px;
    border-style: solid;
  }
  .mughal-border::before { display: none }
  .mughal-border::after { display: none }

  /* ═══ RECENT ENTRIES PANEL — rectangular hashiya-bordered ledger ═══ */
  .recent-panel {
    position: relative;
    background: none;
    border: none;
    padding: 12px 0;
    margin: 8px 0 16px;
    box-shadow: none;
  }
  /* Inner hashiya border */
  .recent-panel::before {
    display: none;
  }
  /* Top ornamental band — multicolor wallpaper palette */
  .recent-panel::after {
    content: '';
    position: absolute;
    top: 0; left: 16px; right: 16px;
    height: 3px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(200,176,232,0.3) 10%,
      rgba(224,144,156,0.4) 25%,
      rgba(144,216,168,0.3) 40%,
      rgba(168,200,240,0.3) 55%,
      rgba(224,144,156,0.4) 70%,
      rgba(200,176,232,0.3) 85%,
      transparent
    );
    pointer-events: none;
  }
  .recent-panel-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    padding-bottom: 10px;
    border-bottom: 1px solid rgba(200,136,152,0.18);
  }
  .recent-panel-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: #5A3E4B;
  }
  .recent-panel-count {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 11px;
    font-style: italic;
    color: rgba(212,160,168,0.7);
  }
  .recent-panel-line {
    flex: 1;
    height: 0.5px;
    background: linear-gradient(90deg, rgba(212,160,168,0.2), transparent);
  }
  /* Corner florets for the rectangular panel */
  .recent-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    opacity: 0.35;
  }
  .recent-corner-tl { top: 3px; left: 3px; }
  .recent-corner-tr { top: 3px; right: 3px; transform: scaleX(-1); }
  .recent-corner-bl { bottom: 3px; left: 3px; transform: scaleY(-1); }
  .recent-corner-br { bottom: 3px; right: 3px; transform: scale(-1); }

  /* ═══ SECTION ORNAMENTAL DIVIDER ═══ */
  .ornamental-divider {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin: 16px 0;
    opacity: 0.5;
  }
  .ornamental-divider-line {
    height: 1px;
    flex: 1;
    max-width: 60px;
    background: linear-gradient(90deg, transparent, rgba(240,160,180,0.5), transparent);
  }

}

@layer utilities {
  .animate-fadeIn { animation: fadeIn .4s ease }
  .animate-scaleIn { animation: scaleIn .5s ease }
  .animate-slideDown { animation: slideDown .3s ease }
  .animate-float { animation: gentleFloat 6s ease-in-out infinite }
  .animate-breathe { animation: breathe 4s ease-in-out infinite }
}
@keyframes fadeIn { from { opacity: 0; transform: translateY(6px) } to { opacity: 1; transform: translateY(0) } }
@keyframes scaleIn { from { opacity: 0; transform: scale(.94) translateY(8px) } to { opacity: 1; transform: scale(1) translateY(0) } }
@keyframes slideDown { from { opacity: 0; transform: translateY(-4px) } to { opacity: 1; transform: translateY(0) } }
@keyframes gentleFloat { 0%,100% { transform: translateY(0) } 50% { transform: translateY(-3px) } }
@keyframes breathe { 0%,100% { opacity: 0.12 } 50% { opacity: 0.22 } }

::-webkit-scrollbar { width: 5px }
::-webkit-scrollbar-track { background: transparent }
::-webkit-scrollbar-thumb { background: rgba(240,160,180,0.3); border-radius: 3px }
@media print { body { background: white !important } .no-print { display: none !important } }
@supports (padding: env(safe-area-inset-bottom)) { body { padding-bottom: env(safe-area-inset-bottom) } }
@media (prefers-reduced-motion: reduce) { *,*::before,*::after { animation-duration: .01ms !important; transition-duration: .01ms !important } }
